# Docker Compose uses the POSTGRES_* values to initialize PostgreSQL, while
# Drizzle and the app use DATABASE_URL. Keep the credentials and database name
# in DATABASE_URL in sync with the individual POSTGRES_* values below.
#
# The included docker-compose.yml maps PostgreSQL to localhost:5433 on the host.
POSTGRES_USER=personal_api
POSTGRES_PASSWORD=personal_api_password
POSTGRES_DB=personal_api
DATABASE_URL=postgresql://personal_api:personal_api_password@localhost:5433/personal_api

# Better Auth
# BETTER_AUTH_SECRET: random string >= 32 chars, run `openssl rand -base64 32` to generate
# BETTER_AUTH_URL:    public base URL of the API (no trailing slash)
BETTER_AUTH_SECRET=replace_with_at_least_32_random_characters
BETTER_AUTH_URL=http://localhost:3000
