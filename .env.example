# Docker Compose uses the POSTGRES_* values to initialize PostgreSQL, while
# Drizzle and the app use DATABASE_URL. Keep the credentials and database name
# in DATABASE_URL in sync with the individual POSTGRES_* values below.
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_postgres_database
DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@localhost:5432/your_postgres_database
